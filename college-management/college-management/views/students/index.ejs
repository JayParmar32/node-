<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1 class="page-title">Students</h1>
    <p class="page-sub">Manage all enrolled students</p>
  </div>
  <a href="/students/add" class="btn btn-primary"><i class="fas fa-plus"></i> Add Student</a>
</div>

<!-- Filters -->
<div class="filter-bar">
  <form action="/students" method="GET" class="filter-form">
    <div class="search-input">
      <i class="fas fa-search"></i>
      <input type="text" name="search" placeholder="Search by name, enrollment, email..." value="<%= query.search || '' %>">
    </div>
    <select name="department">
      <option value="">All Departments</option>
      <% departments.forEach(d => { %>
      <option value="<%= d._id %>" <%= query.department == d._id ? 'selected' : '' %>><%= d.name %></option>
      <% }) %>
    </select>
    <select name="status">
      <option value="">All Status</option>
      <option value="Active" <%= query.status === 'Active' ? 'selected' : '' %>>Active</option>
      <option value="Inactive" <%= query.status === 'Inactive' ? 'selected' : '' %>>Inactive</option>
      <option value="Graduated" <%= query.status === 'Graduated' ? 'selected' : '' %>>Graduated</option>
      <option value="Dropped" <%= query.status === 'Dropped' ? 'selected' : '' %>>Dropped</option>
    </select>
    <select name="semester">
      <option value="">All Semesters</option>
      <% for(let i=1; i<=8; i++) { %>
      <option value="<%= i %>" <%= query.semester == i ? 'selected' : '' %>>Semester <%= i %></option>
      <% } %>
    </select>
    <button type="submit" class="btn btn-primary"><i class="fas fa-filter"></i> Filter</button>
    <a href="/students" class="btn btn-outline">Clear</a>
  </form>
</div>

<!-- Count -->
<div class="result-count"><%= students.length %> student(s) found</div>

<!-- Table -->
<div class="table-card">
  <table class="data-table">
    <thead>
      <tr>
        <th>#</th>
        <th>Student</th>
        <th>Enrollment No.</th>
        <th>Department</th>
        <th>Course</th>
        <th>Semester</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (students.length > 0) { %>
        <% students.forEach((s, i) => { %>
        <tr>
          <td><%= i + 1 %></td>
          <td>
            <div class="name-cell">
              <div class="avatar-sm"><%= s.name.charAt(0).toUpperCase() %></div>
              <div>
                <div class="fw-600"><%= s.name %></div>
                <div class="text-sm text-muted"><%= s.email %></div>
              </div>
            </div>
          </td>
          <td><code><%= s.enrollmentNo %></code></td>
          <td><%= s.department ? s.department.name : '—' %></td>
          <td><%= s.course ? s.course.name : '—' %></td>
          <td><span class="badge badge-blue">Sem <%= s.semester %></span></td>
          <td>
            <span class="badge badge-<%= s.status === 'Active' ? 'green' : s.status === 'Graduated' ? 'purple' : 'gray' %>">
              <%= s.status %>
            </span>
          </td>
          <td>
            <div class="action-btns">
              <a href="/students/<%= s._id %>" class="icon-btn icon-view" title="View"><i class="fas fa-eye"></i></a>
              <a href="/students/<%= s._id %>/edit" class="icon-btn icon-edit" title="Edit"><i class="fas fa-edit"></i></a>
              <form action="/students/<%= s._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this student?')">
                <button type="submit" class="icon-btn icon-delete" title="Delete"><i class="fas fa-trash"></i></button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      <% } else { %>
        <tr><td colspan="8" class="empty-row"><i class="fas fa-user-slash"></i> No students found</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
