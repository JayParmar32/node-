<%- include('./partials/header') %>

<div class="page-header">
  <h1 class="page-title">Dashboard Overview</h1>
  <p class="page-sub">Welcome back, <%= admin.name %>! Here's what's happening today.</p>
</div>

<!-- Stats Cards -->
<div class="stats-grid">
  <div class="stat-card stat-blue">
    <div class="stat-icon"><i class="fas fa-user-graduate"></i></div>
    <div class="stat-info">
      <div class="stat-number"><%= stats.students %></div>
      <div class="stat-label">Total Students</div>
      <div class="stat-sub"><span class="badge badge-green"><%= stats.activeStudents %> Active</span></div>
    </div>
  </div>
  <div class="stat-card stat-purple">
    <div class="stat-icon"><i class="fas fa-chalkboard-teacher"></i></div>
    <div class="stat-info">
      <div class="stat-number"><%= stats.faculty %></div>
      <div class="stat-label">Total Faculty</div>
      <div class="stat-sub"><span class="badge badge-green"><%= stats.activeFaculty %> Active</span></div>
    </div>
  </div>
  <div class="stat-card stat-orange">
    <div class="stat-icon"><i class="fas fa-building"></i></div>
    <div class="stat-info">
      <div class="stat-number"><%= stats.departments %></div>
      <div class="stat-label">Departments</div>
      <div class="stat-sub"><span class="badge badge-blue">All Active</span></div>
    </div>
  </div>
  <div class="stat-card stat-teal">
    <div class="stat-icon"><i class="fas fa-book-open"></i></div>
    <div class="stat-info">
      <div class="stat-number"><%= stats.courses %></div>
      <div class="stat-label">Courses</div>
      <div class="stat-sub"><span class="badge badge-blue">Offered</span></div>
    </div>
  </div>
</div>

<!-- Quick Actions -->
<div class="quick-actions">
  <h2 class="section-title">Quick Actions</h2>
  <div class="actions-grid">
    <a href="/students/add" class="action-btn">
      <i class="fas fa-user-plus"></i>
      <span>Add Student</span>
    </a>
    <a href="/faculty/add" class="action-btn">
      <i class="fas fa-user-tie"></i>
      <span>Add Faculty</span>
    </a>
    <a href="/departments/add" class="action-btn">
      <i class="fas fa-plus-circle"></i>
      <span>Add Department</span>
    </a>
    <a href="/courses/add" class="action-btn">
      <i class="fas fa-book-medical"></i>
      <span>Add Course</span>
    </a>
  </div>
</div>

<!-- Recent Tables -->
<div class="dashboard-tables">
  <div class="table-card">
    <div class="table-header">
      <h3>Recent Students</h3>
      <a href="/students" class="view-all">View All <i class="fas fa-arrow-right"></i></a>
    </div>
    <table class="data-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Enrollment</th>
          <th>Department</th>
          <th>Sem</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% if (recentStudents.length > 0) { %>
          <% recentStudents.forEach(s => { %>
          <tr>
            <td><div class="name-cell"><div class="avatar-sm"><%= s.name.charAt(0) %></div><%= s.name %></div></td>
            <td><code><%= s.enrollmentNo %></code></td>
            <td><%= s.department ? s.department.name : 'N/A' %></td>
            <td>Sem <%= s.semester %></td>
            <td><span class="badge badge-<%= s.status === 'Active' ? 'green' : 'gray' %>"><%= s.status %></span></td>
          </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="5" class="empty-row">No students yet</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="table-card">
    <div class="table-header">
      <h3>Recent Faculty</h3>
      <a href="/faculty" class="view-all">View All <i class="fas fa-arrow-right"></i></a>
    </div>
    <table class="data-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Employee ID</th>
          <th>Designation</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% if (recentFaculty.length > 0) { %>
          <% recentFaculty.forEach(f => { %>
          <tr>
            <td><div class="name-cell"><div class="avatar-sm avatar-purple"><%= f.name.charAt(0) %></div><%= f.name %></div></td>
            <td><code><%= f.employeeId %></code></td>
            <td><%= f.designation %></td>
            <td><span class="badge badge-<%= f.status === 'Active' ? 'green' : 'gray' %>"><%= f.status %></span></td>
          </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="4" class="empty-row">No faculty yet</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('./partials/footer') %>
