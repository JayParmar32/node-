<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1 class="page-title">Courses</h1>
    <p class="page-sub">Manage all offered academic courses</p>
  </div>
  <a href="/courses/add" class="btn btn-primary"><i class="fas fa-plus"></i> Add Course</a>
</div>

<div class="table-card">
  <table class="data-table">
    <thead>
      <tr>
        <th>#</th>
        <th>Course Name</th>
        <th>Code</th>
        <th>Department</th>
        <th>Duration</th>
        <th>Semesters</th>
        <th>Fees (₹)</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (courses.length > 0) { %>
        <% courses.forEach((c, i) => { %>
        <tr>
          <td><%= i + 1 %></td>
          <td>
            <div class="fw-600"><%= c.name %></div>
            <% if (c.description) { %><div class="text-sm text-muted"><%= c.description.substring(0, 50) %>...</div><% } %>
          </td>
          <td><code><%= c.code %></code></td>
          <td><%= c.department ? c.department.name : '—' %></td>
          <td><%= c.duration %> Year<%= c.duration > 1 ? 's' : '' %></td>
          <td><%= c.totalSemesters %> Sem</td>
          <td><%= c.fees ? '₹' + c.fees.toLocaleString() : '—' %></td>
          <td><span class="badge badge-<%= c.status === 'Active' ? 'green' : 'gray' %>"><%= c.status %></span></td>
          <td>
            <div class="action-btns">
              <a href="/courses/<%= c._id %>/edit" class="icon-btn icon-edit" title="Edit"><i class="fas fa-edit"></i></a>
              <form action="/courses/<%= c._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this course?')">
                <button type="submit" class="icon-btn icon-delete" title="Delete"><i class="fas fa-trash"></i></button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      <% } else { %>
        <tr><td colspan="9" class="empty-row"><i class="fas fa-book-open"></i> No courses yet</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
