<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1 class="page-title">Edit Faculty</h1>
    <p class="page-sub"><%= faculty.name %> &mdash; <%= faculty.employeeId %></p>
  </div>
  <a href="/faculty/<%= faculty._id %>" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
</div>

<div class="form-card">
  <form action="/faculty/<%= faculty._id %>?_method=PUT" method="POST">
    <div class="form-section">
      <h3 class="form-section-title"><i class="fas fa-user-tie"></i> Personal Information</h3>
      <div class="form-grid">
        <div class="form-group">
          <label>Full Name <span class="required">*</span></label>
          <input type="text" name="name" value="<%= faculty.name %>" required>
        </div>
        <div class="form-group">
          <label>Employee ID <span class="required">*</span></label>
          <input type="text" name="employeeId" value="<%= faculty.employeeId %>" required>
        </div>
        <div class="form-group">
          <label>Email <span class="required">*</span></label>
          <input type="email" name="email" value="<%= faculty.email %>" required>
        </div>
        <div class="form-group">
          <label>Phone <span class="required">*</span></label>
          <input type="tel" name="phone" value="<%= faculty.phone %>" required>
        </div>
        <div class="form-group">
          <label>Gender <span class="required">*</span></label>
          <select name="gender" required>
            <option value="Male" <%= faculty.gender === 'Male' ? 'selected' : '' %>>Male</option>
            <option value="Female" <%= faculty.gender === 'Female' ? 'selected' : '' %>>Female</option>
            <option value="Other" <%= faculty.gender === 'Other' ? 'selected' : '' %>>Other</option>
          </select>
        </div>
        <div class="form-group">
          <label>Date of Birth</label>
          <input type="date" name="dob" value="<%= faculty.dob ? new Date(faculty.dob).toISOString().split('T')[0] : '' %>">
        </div>
        <div class="form-group form-full">
          <label>Address</label>
          <textarea name="address" rows="2"><%= faculty.address || '' %></textarea>
        </div>
      </div>
    </div>
    <div class="form-section">
      <h3 class="form-section-title"><i class="fas fa-briefcase"></i> Professional Details</h3>
      <div class="form-grid">
        <div class="form-group">
          <label>Qualification <span class="required">*</span></label>
          <input type="text" name="qualification" value="<%= faculty.qualification %>" required>
        </div>
        <div class="form-group">
          <label>Designation <span class="required">*</span></label>
          <input type="text" name="designation" value="<%= faculty.designation %>" required>
        </div>
        <div class="form-group">
          <label>Department <span class="required">*</span></label>
          <select name="department" required>
            <% departments.forEach(d => { %>
            <option value="<%= d._id %>" <%= faculty.department && faculty.department.toString() === d._id.toString() ? 'selected' : '' %>><%= d.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Salary (₹)</label>
          <input type="number" name="salary" value="<%= faculty.salary || '' %>">
        </div>
        <div class="form-group">
          <label>Status</label>
          <select name="status">
            <option value="Active" <%= faculty.status === 'Active' ? 'selected' : '' %>>Active</option>
            <option value="Inactive" <%= faculty.status === 'Inactive' ? 'selected' : '' %>>Inactive</option>
            <option value="On Leave" <%= faculty.status === 'On Leave' ? 'selected' : '' %>>On Leave</option>
          </select>
        </div>
        <div class="form-group form-full">
          <label>Subjects <span class="text-muted">(comma separated)</span></label>
          <input type="text" name="subjects" value="<%= faculty.subjects ? faculty.subjects.join(', ') : '' %>">
        </div>
      </div>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Update Faculty</button>
      <a href="/faculty/<%= faculty._id %>" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
