<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1 class="page-title">Departments</h1>
    <p class="page-sub">Manage college departments</p>
  </div>
  <a href="/departments/add" class="btn btn-primary"><i class="fas fa-plus"></i> Add Department</a>
</div>

<div class="cards-grid">
  <% if (departments.length > 0) { %>
    <% departments.forEach(d => { %>
    <div class="dept-card">
      <div class="dept-card-header">
        <div class="dept-icon"><i class="fas fa-building"></i></div>
        <div class="dept-badge">
          <span class="badge badge-<%= d.status === 'Active' ? 'green' : 'gray' %>"><%= d.status %></span>
        </div>
      </div>
      <h3 class="dept-name"><%= d.name %></h3>
      <p class="dept-code">Code: <code><%= d.code %></code></p>
      <% if (d.head) { %><p class="dept-info"><i class="fas fa-user-tie"></i> HOD: <%= d.head %></p><% } %>
      <% if (d.established) { %><p class="dept-info"><i class="fas fa-calendar"></i> Est. <%= d.established %></p><% } %>
      <% if (d.description) { %><p class="dept-desc"><%= d.description %></p><% } %>
      <div class="dept-actions">
        <a href="/departments/<%= d._id %>/edit" class="btn btn-sm btn-outline"><i class="fas fa-edit"></i> Edit</a>
        <form action="/departments/<%= d._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this department? Make sure no students or faculty are linked.')">
          <button type="submit" class="btn btn-sm btn-danger-outline"><i class="fas fa-trash"></i> Delete</button>
        </form>
      </div>
    </div>
    <% }) %>
  <% } else { %>
    <div class="empty-state">
      <i class="fas fa-building"></i>
      <h3>No Departments Yet</h3>
      <p>Create your first department to get started.</p>
      <a href="/departments/add" class="btn btn-primary">Add Department</a>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
