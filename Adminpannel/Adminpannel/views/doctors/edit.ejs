<%- include('../partials/header') %>
<div class="app-container">
    <%- include('../partials/sidebar') %>
    <main class="main-content">
        <div class="page-header">
            <h1 class="page-title">Edit Doctor: <%= doctor.name %></h1>
            <a href="/doctors" class="btn" style="background: var(--border); color: var(--text-primary);">Back to List</a>
        </div>
        <div class="glass form-container">
            <form action="/doctors/edit/<%= doctor._id %>?_method=PUT" method="POST">
                <div class="input-group">
                    <label>Full Name</label>
                    <input type="text" name="name" value="<%= doctor.name %>" required>
                </div>
                <div class="input-group">
                    <label>Specialization</label>
                    <input type="text" name="specialization" value="<%= doctor.specialization %>" required>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label>Email Address</label>
                        <input type="email" name="email" value="<%= doctor.email %>" required>
                    </div>
                    <div class="input-group">
                        <label>Phone Number</label>
                        <input type="text" name="phone" value="<%= doctor.phone %>" required>
                    </div>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label>Experience (Years)</label>
                        <input type="number" name="experience" min="0" value="<%= doctor.experience %>">
                    </div>
                    <div class="input-group">
                        <label>Status</label>
                        <select name="status">
                            <option value="Active" <%= doctor.status === 'Active' ? 'selected' : '' %>>Active</option>
                            <option value="Inactive" <%= doctor.status === 'Inactive' ? 'selected' : '' %>>Inactive</option>
                        </select>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary" style="margin-top: 1rem;">Update Doctor Profile</button>
            </form>
        </div>
    </main>
</div>
<%- include('../partials/footer') %>
