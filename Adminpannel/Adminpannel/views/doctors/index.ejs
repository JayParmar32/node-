<%- include('../partials/header') %>
<div class="app-container">
    <%- include('../partials/sidebar') %>
    <main class="main-content">
        <div class="page-header">
            <h1 class="page-title">Manage Doctors</h1>
            <a href="/doctors/add" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Add New Doctor</a>
        </div>
        <div class="glass table-container">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Specialization</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (doctors && doctors.length > 0) { %>
                        <% doctors.forEach(doc => { %>
                            <tr>
                                <td style="font-weight: 600;"><%= doc.name %></td>
                                <td><span class="badge" style="background:#e0f2fe; color:#0284c7;"><%= doc.specialization %></span></td>
                                <td><%= doc.email %></td>
                                <td><%= doc.phone %></td>
                                <td>
                                    <span class="badge badge-<%= doc.status === 'Active' ? 'completed' : 'cancelled' %>">
                                        <%= doc.status %>
                                    </span>
                                </td>
                                <td>
                                    <a href="/doctors/edit/<%= doc._id %>" class="btn action-btn btn-edit"><i class="fa-solid fa-pen"></i></a>
                                    <form action="/doctors/delete/<%= doc._id %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this doctor?');">
                                        <button type="submit" class="btn action-btn btn-delete"><i class="fa-solid fa-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="6" style="text-align: center; padding: 2rem; color: var(--text-secondary);">No doctors found. Add a doctor to get started.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>
</div>
<%- include('../partials/footer') %>
