<%- include('../partials/header') %>
<div class="app-container">
    <%- include('../partials/sidebar') %>
    <main class="main-content">
        <div class="page-header">
            <h1 class="page-title">Manage Appointments</h1>
            <a href="/appointments/add" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Schedule Appointment</a>
        </div>
        <div class="glass table-container">
            <table>
                <thead>
                    <tr>
                        <th>Patient</th>
                        <th>Doctor</th>
                        <th>Date & Time</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (appointments && appointments.length > 0) { %>
                        <% appointments.forEach(apt => { %>
                            <tr>
                                <td style="font-weight: 600;"><%= apt.patient.name %></td>
                                <td><i class="fa-solid fa-user-doctor" style="color:var(--secondary)"></i> <%= apt.doctor.name %></td>
                                <td>
                                    <div style="font-weight:500;"><%= new Date(apt.date).toLocaleDateString() %></div>
                                    <div style="font-size:0.85rem; color:var(--text-secondary);"><%= apt.time %></div>
                                </td>
                                <td>
                                    <span class="badge badge-<%= apt.status.toLowerCase() %>">
                                        <%= apt.status %>
                                    </span>
                                </td>
                                <td>
                                    <a href="/appointments/edit/<%= apt._id %>" class="btn action-btn btn-edit"><i class="fa-solid fa-pen"></i></a>
                                    <form action="/appointments/delete/<%= apt._id %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this appointment?');">
                                        <button type="submit" class="btn action-btn btn-delete"><i class="fa-solid fa-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="5" style="text-align: center; padding: 2rem; color: var(--text-secondary);">No appointments found. Schedule an appointment to get started.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>
</div>
<%- include('../partials/footer') %>
