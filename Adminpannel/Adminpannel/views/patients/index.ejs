<%- include('../partials/header') %>
<div class="app-container">
    <%- include('../partials/sidebar') %>
    <main class="main-content">
        <div class="page-header">
            <h1 class="page-title">Manage Patients</h1>
            <a href="/patients/add" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Add New Patient</a>
        </div>
        <div class="glass table-container">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Age/Gender</th>
                        <th>Blood Group</th>
                        <th>Contact</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (patients && patients.length > 0) { %>
                        <% patients.forEach(patient => { %>
                            <tr>
                                <td style="font-weight: 600;"><%= patient.name %></td>
                                <td><%= patient.age %> / <%= patient.gender %></td>
                                <td><span class="badge" style="background:#fce7f3; color:#be185d;"><%= patient.bloodGroup || 'N/A' %></span></td>
                                <td><%= patient.contact %></td>
                                <td>
                                    <a href="/patients/edit/<%= patient._id %>" class="btn action-btn btn-edit"><i class="fa-solid fa-pen"></i></a>
                                    <form action="/patients/delete/<%= patient._id %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this patient?');">
                                        <button type="submit" class="btn action-btn btn-delete"><i class="fa-solid fa-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="5" style="text-align: center; padding: 2rem; color: var(--text-secondary);">No patients found. Add a patient to get started.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>
</div>
<%- include('../partials/footer') %>
