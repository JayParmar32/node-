<%- include('partials/header') %>

<div class="app-container">
    <%- include('partials/sidebar') %>
    
    <main class="main-content">
        <div class="page-header">
            <h1 class="page-title">Dashboard Overview</h1>
            <div style="font-weight: 500; color: var(--text-secondary);">
                Welcome back, Administrator
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card glass">
                <div class="stat-icon bg-blue">
                    <i class="fa-solid fa-user-doctor"></i>
                </div>
                <div class="stat-info">
                    <h3>Total Doctors</h3>
                    <p><%= stats.totalDoctors %></p>
                </div>
            </div>
            <div class="stat-card glass">
                <div class="stat-icon bg-green">
                    <i class="fa-solid fa-users"></i>
                </div>
                <div class="stat-info">
                    <h3>Total Patients</h3>
                    <p><%= stats.totalPatients %></p>
                </div>
            </div>
            <div class="stat-card glass">
                <div class="stat-icon bg-purple">
                    <i class="fa-solid fa-calendar-check"></i>
                </div>
                <div class="stat-info">
                    <h3>Total Appointments</h3>
                    <p><%= stats.totalAppointments %></p>
                </div>
            </div>
            <div class="stat-card glass">
                <div class="stat-icon bg-orange">
                    <i class="fa-solid fa-clock"></i>
                </div>
                <div class="stat-info">
                    <h3>Today's Appointments</h3>
                    <p><%= stats.todayAppointments %></p>
                </div>
            </div>
        </div>

        <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1rem; margin-top: 2rem;">Recent Appointments</h2>
        <div class="glass table-container">
            <table>
                <thead>
                    <tr>
                        <th>Patient Name</th>
                        <th>Doctor Name</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (recentAppointments && recentAppointments.length > 0) { %>
                        <% recentAppointments.forEach(apt => { %>
                            <tr>
                                <td style="font-weight: 600;"><%= apt.patient.name %></td>
                                <td><%= apt.doctor.name %></td>
                                <td><%= new Date(apt.date).toLocaleDateString() %></td>
                                <td><%= apt.time %></td>
                                <td>
                                    <span class="badge badge-<%= apt.status.toLowerCase() %>">
                                        <%= apt.status %>
                                    </span>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" style="text-align: center; color: var(--text-secondary); padding: 2rem;">
                                No recent appointments found.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>
</div>

<%- include('partials/footer') %>
