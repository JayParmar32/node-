<!DOCTYPE html>
<html>
<head>
  <title><%= blog.title %></title>

</head>
<body>
  <h1><%= blog.title %></h1>
  <p><strong>Author:</strong> <%= blog.author %></p>
  <p><%= blog.content %></p>
  <a href="/blogs/<%= blog._id %>/edit">Edit</a>
  <br> <br>

  <form action="/blogs/<%= blog._id %>?_method=DELETE" method="POST">
    <button type="submit">Delete</button>
  </form>

  <br>
  <a href="/">Back</a>
</body>
</html>