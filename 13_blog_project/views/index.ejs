<!DOCTYPE html>
<html>
<head>
  <title>All Blogs</title>
    <link rel="stylesheet" href="/styles.css">

</head>
<body>
  <h1>Blog Posts</h1>
  <a href="/blogs/new">Create New Blog</a>
  <hr>

  <% blogs.forEach(blog => { %>
    <h3><%= blog.title %></h3>
    <p>By <%= blog.author %></p>
    <a href="/blogs/<%= blog._id %>">Read More</a>
    <hr>
  <% }) %>
</body>
</html>