<!DOCTYPE html>
<html>
<head>
  <title>Edit Blog</title>
</head>
<body>
  <h1>Edit Blog</h1>

  <form action="/blogs/<%= blog._id %>?_method=PUT" method="POST">
    <input type="text" name="title" value="<%= blog.title %>" required><br><br>
    <input type="text" name="author" value="<%= blog.author %>" required><br><br>
    <textarea name="content" required><%= blog.content %></textarea><br><br>
    <button type="submit">Update</button>
  </form>

  <a href="/" >Back</a>
</body>
</html>